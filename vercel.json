{
  "framework": null,
  "redirects": [
    { "source": "/lab", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "/", "permanent": true },
    { "source": "/lab/:path(.*)", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "/", "permanent": true },
    { "source": "/index.html", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "https://ericli.n5hq.me/", "permanent": true },
    { "source": "/blog", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "https://ericli.n5hq.me/blog/", "permanent": true },
    { "source": "/blog/:path(.*)", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "https://ericli.n5hq.me/blog/:path", "permanent": true },
    { "source": "/portfolio/:path(.*)", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "https://ericli.n5hq.me/portfolio/:path", "permanent": true },
    { "source": "/lab", "has": [{ "type": "host", "value": "ericli.n5hq.me" }], "destination": "https://www.n5hq.me/", "permanent": true },
    { "source": "/lab/:path(.*)", "has": [{ "type": "host", "value": "ericli.n5hq.me" }], "destination": "https://www.n5hq.me/", "permanent": true },
    { "source": "/portal", "has": [{ "type": "host", "value": "ericli.n5hq.me" }], "destination": "https://portal.n5hq.me/", "permanent": true },
    { "source": "/portal/:path(.*)", "has": [{ "type": "host", "value": "ericli.n5hq.me" }], "destination": "https://portal.n5hq.me/", "permanent": true },
    { "source": "/portal", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "https://portal.n5hq.me/", "permanent": true },
    { "source": "/portal/:path(.*)", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "https://portal.n5hq.me/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home/:path(.*)", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "/lab/index.html" },
    { "source": "/", "destination": "/home/index.html" },
    { "source": "/sitemap.xml", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "/sitemap-www.xml" },
    { "source": "/robots.txt", "has": [{ "type": "host", "value": "www.n5hq.me" }], "destination": "/robots-www.txt" },
    { "source": "/sitemap.xml", "has": [{ "type": "host", "value": "ericli.n5hq.me" }], "destination": "/sitemap-ericli.xml" },
    { "source": "/robots.txt", "has": [{ "type": "host", "value": "ericli.n5hq.me" }], "destination": "/robots-ericli.txt" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/lab", "destination": "/lab/index.html" },
    { "source": "/portfolio/in-progress", "destination": "/portfolio/in-progress/index.html" },
    { "source": "/portfolio/upcoming", "destination": "/portfolio/upcoming/index.html" },
    { "source": "/portfolio/completed", "destination": "/portfolio/completed/index.html" },
    { "source": "/portfolio/homelab", "destination": "/portfolio/homelab/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
